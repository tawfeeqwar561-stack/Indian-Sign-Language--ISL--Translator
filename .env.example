# ============================================
# ISL Translation System - Environment Config
# ============================================

# Flask
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-in-production-abc123
HOST=0.0.0.0
PORT=5000

# Database
DATABASE_URL=sqlite:///isl_translation.db

# Redis
REDIS_URL=redis://localhost:6379/0

# Model paths
MODEL_DIR=./backend/saved_models

# GPU
USE_GPU=false
NUM_INFERENCE_THREADS=4

# TTS
TTS_ENGINE=gtts

# Federated Learning
FL_ENABLED=false
FL_MIN_CLIENTS=3
FL_ROUNDS=10
FL_LOCAL_EPOCHS=5

# Logging
LOG_LEVEL=INFO
LOG_FILE=isl_system.log