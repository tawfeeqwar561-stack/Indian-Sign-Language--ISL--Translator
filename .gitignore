# ═══════════════════════════════════════════════════════════
# ISL Translation System — .gitignore
# Keep: frontend/, backend/, ml_pipeline/, docker, README
# ═══════════════════════════════════════════════════════════

# ── Python ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
.eggs/

# ── Virtual Environments ─────────────────────────────────
.venv/
venv/
backend/venv/
backend/venv2/
env/
ENV/

# ── Node / Frontend ──────────────────────────────────────
node_modules/
frontend/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp/
.pnp.js

# ── Environment & Secrets ────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# Keep .env.example as reference
!.env.example

# ── IDE / Editor ─────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ── Logs ─────────────────────────────────────────────────
*.log
backend/isl_system.log

# ── Database (SQLite) ────────────────────────────────────
backend/instance/
*.db
*.sqlite3

# ── Generated / Cache ───────────────────────────────────
backend/saved_models/
backend/resources/pdfs/*.pdf
backend/resources/pdfs/.gitkeep
frontend/tfjs_models/

# ── ML Models & large data ──────────────────────────────
*.h5
*.hdf5
*.pkl
*.joblib
*.onnx
*.tflite
*.pt
*.pth
*.pb
*.ckpt
*.safetensors
ml_pipeline/data/*.csv
ml_pipeline/data/*.json
ml_pipeline/data/*.npy

# ── Docker (runtime) ────────────────────────────────────
# Keep Dockerfiles and docker-compose.yml
# Ignore runtime artifacts
.docker/

# ── OS Files ─────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── Misc ─────────────────────────────────────────────────
*.bak
*.tmp
*.temp
coverage/
.nyc_output/
