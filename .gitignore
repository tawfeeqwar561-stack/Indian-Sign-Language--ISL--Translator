# ═══════════════════════════════════════════════════════════
# ISL Translation System — .gitignore
# ═══════════════════════════════════════════════════════════
# ONLY these are tracked in Git:
#   frontend/    (source code)
#   backend/     (source code)
#   ml_pipeline/ (source code)
#   Dockerfile.backend, Dockerfile.frontend, docker-compose.yml
#   README.md, .gitignore, .env.example, start.bat
# Everything else is ignored.
# ═══════════════════════════════════════════════════════════

# ── Ignore everything by default ─────────────────────────
*

# ── Then whitelist the folders/files we want ─────────────
!.gitignore
!README.md
!.env.example
!start.bat

# Docker files
!Dockerfile.backend
!Dockerfile.frontend
!docker-compose.yml

# ── Whitelist frontend/ (recursively) ────────────────────
!frontend/
!frontend/**

# ── Whitelist backend/ (recursively) ─────────────────────
!backend/
!backend/**

# ── Whitelist ml_pipeline/ (recursively) ─────────────────
!ml_pipeline/
!ml_pipeline/**

# ═══════════════════════════════════════════════════════════
# Now IGNORE heavy/generated stuff INSIDE those folders
# ═══════════════════════════════════════════════════════════

# ── Python caches ────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so

# ── Virtual Environments (anywhere) ──────────────────────
.venv/
venv/
venv2/
env/
ENV/

# ── Node modules ─────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp/
.pnp.js

# ── Environment / secrets ────────────────────────────────
.env
.env.local
.env.*.local

# ── IDE / Editor ─────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Logs ─────────────────────────────────────────────────
*.log

# ── Database ─────────────────────────────────────────────
*.db
*.sqlite3
backend/instance/

# ── Generated / Cached artifacts ─────────────────────────
backend/saved_models/
backend/resources/pdfs/*.pdf
backend/resources/pdfs/.gitkeep
frontend/tfjs_models/

# ── ML model binaries & large data ──────────────────────
*.h5
*.hdf5
*.pkl
*.joblib
*.onnx
*.tflite
*.pt
*.pth
*.pb
*.ckpt
*.safetensors
*.npy
*.npz

# ── OS files ─────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── Build artifacts ──────────────────────────────────────
dist/
build/
coverage/
.nyc_output/
*.egg-info/
*.egg
.eggs/
*.bak
*.tmp
*.temp
